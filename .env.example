# Database
DATABASE_URL="postgresql://user:password@localhost:5432/trini_swap_or_sell"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# PayPal Configuration
# Get these from https://developer.paypal.com/
NEXT_PUBLIC_PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
PAYPAL_WEBHOOK_ID="your-paypal-webhook-id"
PAYPAL_MODE="sandbox" # or "live" for production

# Posting Fee Configuration
POSTING_FEE_AMOUNT="10" # Base posting fee in TTD
POSTING_FEE_CURRENCY="TTD"

# AWS S3 Configuration (for file uploads)
# These are automatically set by the platform
AWS_BUCKET_NAME=""
AWS_FOLDER_PREFIX=""
AWS_REGION="us-east-1"
