// Freezone Swap or Sell - Prisma Schema
// Complete database schema for marketplace with membership tiers, listings, payments, and swaps

generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  USER
  ADMIN
}

enum MembershipTier {
  FREE
  BASIC
  PRO
  BUSINESS
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  NONE
}

enum ListingType {
  SELL
  SWAP
  BOTH
  FREE
}

enum ListingStatus {
  DRAFT
  PENDING_APPROVAL
  PENDING_PAYMENT
  ACTIVE
  EXPIRED
  REJECTED
  SOLD
  SWAPPED
  REMOVED
}

enum BannerStatus {
  PENDING_PAYMENT
  PENDING_VERIFICATION
  ACTIVE
  EXPIRED
  REJECTED
}

enum ListingCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  POOR
}

enum PaymentMethod {
  PAYPAL
  ONLINE_BANK
  BANK_DEPOSIT
}

enum PaymentStatus {
  CREATED
  PENDING
  PAID
  VERIFIED
  REJECTED
  FAILED
}

enum SwapOfferStatus {
  OFFERED
  ACCEPTED
  DECLINED
  CANCELLED
  COMPLETED
}

enum FeaturedStatus {
  NONE
  PENDING_PAYMENT
  ACTIVE
  EXPIRED
}

// ============================================================
// MODELS
// ============================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  
  // Membership & Subscription
  tier                  MembershipTier     @default(FREE)
  subscriptionStatus    SubscriptionStatus @default(NONE)
  subscriptionStart     DateTime?
  subscriptionEnd       DateTime?
  sellListingsThisMonth Int                @default(0)
  monthlyResetAt        DateTime?
  trialEndsAt           DateTime?
  hasUsedFreeRegularPost Boolean           @default(false)
  
  // Profile
  phone         String?
  location      String?
  bio           String?
  avatar        String?
  verified      Boolean  @default(false)
  banned        Boolean  @default(false)
  
  // Password Reset
  resetToken       String?
  resetTokenExpiry DateTime?
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  listings          Listing[]
  feePayments       FeePayment[]
  swapOffersFrom    SwapOffer[]   @relation("SwapOfferFromUser")
  swapOffersTo      SwapOffer[]   @relation("SwapOfferToUser")
  conversationsAs1  Conversation[] @relation("ConversationParticipant1")
  conversationsAs2  Conversation[] @relation("ConversationParticipant2")
  messages          Message[]
  notifications     Notification[]
  accounts          Account[]
  sessions          Session[]
  wishlistItems     Wishlist[]
  bannerAds         BannerAd[]
  preferences       UserPreferences?
  displayName       String?
  whatsapp          String?
  
  @@index([email])
  @@index([tier])
  @@index([role])
  @@index([createdAt])
}

// ============================================================
// WISHLIST MODEL
// ============================================================

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

model Listing {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String   @db.Text
  category    String
  condition   ListingCondition
  location    String
  price       Float?
  currency    String   @default("TTD")
  listingType ListingType
  status      ListingStatus    @default(DRAFT)
  swapTerms   String?          @db.Text
  images      String[]         @default([])
  views       Int              @default(0)
  featured    Boolean          @default(false)
  featuredUntil DateTime?
  boosted     Boolean          @default(false)
  boostedUntil  DateTime?
  featuredStatus       FeaturedStatus?  @default(NONE)
  featuredPrice        Float?
  featuredStartAt      DateTime?
  featuredExpiresAt    DateTime?
  featuredPaymentProof String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  publishedAt DateTime?
  expiresAt   DateTime?
  activatedAt DateTime?
  soldAt      DateTime?
  rejectedAt  DateTime?
  rejectionReason String?
  feePayments       FeePayment[]
  offeredInSwaps    SwapOffer[]  @relation("OfferedListing")
  requestedInSwaps  SwapOffer[]  @relation("RequestedListing")
  conversations     Conversation[]
  wishlistedBy      Wishlist[]
  
  @@index([userId])
  @@index([status])
  @@index([listingType])
  @@index([category])
  @@index([createdAt])
  @@index([featured])
  @@index([boosted])
}

enum PaymentPurpose {
  LISTING_FEE
  LISTING_RENEWAL
  BANNER_AD
  BANNER_RENEWAL
  FEATURED_LISTING
  FEATURED_RENEWAL
}

model FeePayment {
  id                    String         @id @default(cuid())
  listingId             String?
  listing               Listing?       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bannerAdId            String?
  userId                String
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose               PaymentPurpose @default(LISTING_FEE)
  amount                Float
  currency              String         @default("TTD")
  method                PaymentMethod
  status                PaymentStatus  @default(CREATED)
  providerTransactionId String?        @unique
  paypalOrderId         String?        @unique
  paypalCaptureId       String?        @unique
  reference             String?
  proofUploadUrl        String?
  adminNotes            String?        @db.Text
  verifiedBy            String?
  verifiedAt            DateTime?
  idempotencyKey        String?        @unique
  webhookProcessedAt    DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  
  @@index([listingId])
  @@index([bannerAdId])
  @@index([userId])
  @@index([status])
  @@index([method])
  @@index([purpose])
  @@index([providerTransactionId])
  @@index([createdAt])
}

model SwapOffer {
  id                 String          @id @default(cuid())
  fromUserId         String
  fromUser           User            @relation("SwapOfferFromUser", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId           String
  toUser             User            @relation("SwapOfferToUser", fields: [toUserId], references: [id], onDelete: Cascade)
  offeredListingId   String
  offeredListing     Listing         @relation("OfferedListing", fields: [offeredListingId], references: [id], onDelete: Cascade)
  requestedListingId String
  requestedListing   Listing         @relation("RequestedListing", fields: [requestedListingId], references: [id], onDelete: Cascade)
  status             SwapOfferStatus @default(OFFERED)
  message            String?         @db.Text
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  respondedAt        DateTime?
  swapDeal           SwapDeal?
  
  @@index([fromUserId])
  @@index([toUserId])
  @@index([offeredListingId])
  @@index([requestedListingId])
  @@index([status])
  @@index([createdAt])
}

model SwapDeal {
  id              String    @id @default(cuid())
  swapOfferId     String    @unique
  swapOffer       SwapOffer @relation(fields: [swapOfferId], references: [id], onDelete: Cascade)
  confirmFromUser Boolean   @default(false)
  confirmToUser   Boolean   @default(false)
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([swapOfferId])
  @@index([completedAt])
}

// ============================================================
// MESSAGING MODELS
// ============================================================

model Conversation {
  id             String   @id @default(cuid())
  participant1Id String
  participant1   User     @relation("ConversationParticipant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2Id String
  participant2   User     @relation("ConversationParticipant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  listingId      String?
  listing        Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  messages       Message[]
  
  @@unique([participant1Id, participant2Id, listingId])
  @@index([participant1Id])
  @@index([participant2Id])
  @@index([listingId])
  @@index([updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String       @db.Text
  read           Boolean      @default(false)
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  
  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@index([read])
}

// ============================================================
// NOTIFICATION MODEL
// ============================================================

enum NotificationType {
  MESSAGE
  SWAP_OFFER
  SWAP_ACCEPTED
  SWAP_DECLINED
  PAYMENT_RECEIVED
  LISTING_APPROVED
  LISTING_SOLD
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String           @db.Text
  read      Boolean          @default(false)
  linkUrl   String?
  createdAt DateTime         @default(now())
  
  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

// ============================================================
// NEXTAUTH MODELS
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  
  @@unique([identifier, token])
}

// ============================================================
// BANNER ADS
// ============================================================

model BannerAd {
  id               String       @id @default(cuid())
  title            String
  imageUrl         String
  linkUrl          String?
  placement        String       @default("homepage_top")
  status           BannerStatus @default(PENDING_PAYMENT)
  active           Boolean      @default(false)
  sortOrder        Int          @default(0)
  startsAt         DateTime?
  endsAt           DateTime?
  startDate        DateTime?
  endDate          DateTime?
  clicks           Int          @default(0)
  impressions      Int          @default(0)
  userId           String?
  user             User?        @relation(fields: [userId], references: [id])
  amount           Float        @default(700)
  currency         String       @default("TTD")
  paymentProofUrl  String?
  paymentReference String?
  adminNotes       String?
  verifiedAt       DateTime?
  verifiedBy       String?
  rejectedAt       DateTime?
  rejectionReason  String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  
  @@index([placement, status])
  @@index([userId])
  @@index([status])
  @@index([active])
  @@index([startsAt])
  @@index([endsAt])
}

// ============================================================
// USER PREFERENCES MODEL
// ============================================================

model UserPreferences {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  theme                    String?  @default("system")
  compactMode              Boolean  @default(false)
  reduceMotion             Boolean  @default(false)
  enableAllNotifications   Boolean  @default(true)
  pushNotifications        Boolean  @default(true)
  emailNotifications       Boolean  @default(true)
  inAppNotifications       Boolean  @default(true)
  smsNotifications         Boolean  @default(false)
  whatsappNotifications    Boolean  @default(false)
  notifyNewMessage         Boolean  @default(true)
  notifySellerReplied      Boolean  @default(true)
  notifyOfferAccepted      Boolean  @default(true)
  notifyOfferDeclined      Boolean  @default(true)
  notifyItemSold           Boolean  @default(true)
  notifyItemRelisted       Boolean  @default(true)
  notifyWishlistUpdated    Boolean  @default(true)
  notifyPriceDropped       Boolean  @default(true)
  notifyBuyerMessage       Boolean  @default(true)
  notifyNewOffer           Boolean  @default(true)
  notifyListingApproved    Boolean  @default(true)
  notifyListingExpired     Boolean  @default(true)
  notifyRenewalReminder    Boolean  @default(true)
  notifyListingSold        Boolean  @default(true)
  notifyPerformanceSummary Boolean  @default(false)
  notifyPaymentReceived    Boolean  @default(true)
  notifySwapRequest        Boolean  @default(true)
  notifyNewDeviceLogin     Boolean  @default(true)
  notifyPasswordChanged    Boolean  @default(true)
  notifySecurityAlert      Boolean  @default(true)
  notifyAccountUpdates     Boolean  @default(true)
  notifyPolicyUpdates      Boolean  @default(false)
  notifyPromotionalEmails  Boolean  @default(false)
  profileVisibility        String?  @default("public")
  showPhone                Boolean  @default(false)
  showWhatsapp             Boolean  @default(false)
  showEmail                Boolean  @default(false)
  allowSearchEngineIndex   Boolean  @default(true)
  twoFactorEnabled         Boolean  @default(false)
  defaultBrowseLocation    String?
  preferredCategories      String[] @default([])
  preferredCondition       String?
  showFeaturedFirst        Boolean  @default(true)
  showNewestFirst          Boolean  @default(false)
  hideSoldListings         Boolean  @default(false)
  hideSwapOnly             Boolean  @default(false)
  hideFreeItems            Boolean  @default(false)
  defaultListingView       String?  @default("grid")
  budgetMin                Float?
  budgetMax                Float?
  interestedCategories     String[] @default([])
  acceptInternational      Boolean  @default(false)
  localOnly                Boolean  @default(true)
  meetUpPreferred          Boolean  @default(true)
  deliveryPreferred        Boolean  @default(false)
  autoFollowSearches       Boolean  @default(false)
  notifyMatchingItems      Boolean  @default(false)
  defaultListingType       String?  @default("SELL")
  defaultItemLocation      String?
  defaultCondition         String?  @default("GOOD")
  autoRenewListing         Boolean  @default(false)
  renewalReminder          Boolean  @default(true)
  showSellerPhone          Boolean  @default(false)
  showSellerWhatsapp       Boolean  @default(false)
  allowOffers              Boolean  @default(true)
  allowSwapProposals       Boolean  @default(true)
  vacationMode             Boolean  @default(false)
  autoMarkUnavailable      Boolean  @default(true)
  preferredContactMethod   String?  @default("message")
  allowBuyerMessages       Boolean  @default(true)
  allowLoggedInOnly        Boolean  @default(true)
  muteMessageSounds        Boolean  @default(false)
  emailOnMessage           Boolean  @default(true)
  showReadReceipts         Boolean  @default(true)
  showOnlineStatus         Boolean  @default(true)
  autoReplyMessage         String?  @db.Text
  preferredPaymentMethod   String?
  billingEmail             String?
  billingPhone             String?
  renewalPaymentReminder   Boolean  @default(true)
  invoiceEmailToggle       Boolean  @default(true)
  payoutPreference         String?
  taxId                    String?
  businessName             String?
  transactionMethod        String?  @default("both")
  preferredMeetupAreas     String?  @db.Text
  deliveryAvailable        Boolean  @default(false)
  deliveryFee              String?
  pickupInstructions       String?  @db.Text
  availableTimes           String?  @db.Text
  saveRecentlyViewed       Boolean  @default(true)
  personalizedRecs         Boolean  @default(true)
  recommendedCategories    Boolean  @default(true)
  trendingItems            Boolean  @default(true)
  promotionalSuggestions   Boolean  @default(false)
  homepagePersonalization  Boolean  @default(true)
  facebookUrl              String?
  instagramUrl             String?
  tiktokUrl                String?
  websiteUrl               String?
  storeName                String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([userId])
}

// ============================================================
// SITE SETTINGS MODEL
// ============================================================

model SiteSettings {
  id        String   @id @default("site_settings")
  phone     String   @default("290-1117")
  whatsapp  String   @default("752-2936")
  email1    String   @default("khaliff@email.com")
  email2    String   @default("freezone@marketplace.com")
  tiktok    String   @default("freezone@tt")
  facebook  String   @default("Freezonett")
  instagram String   @default("Freezonett")
  updatedAt DateTime @updatedAt
}
